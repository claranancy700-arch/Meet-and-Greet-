# App settings
NODE_ENV=production
PORT=3000
ADMIN_SECRET=meet-2026-admin

# PostgreSQL connection
DATABASE_URL=postgresql://username:password@hostname:5432/databasename
# Alternatively define these separately if your host does not supply DATABASE_URL
# PGHOST=hostname
# PGPORT=5432
# PGUSER=username
# PGPASSWORD=password
# PGDATABASE=databasename

# SSL if required by your DB provider
DATABASE_SSL=true
